# Database connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URI=postgresql://postgres:password@localhost:5432/greenvoltt

# Payload secret key - generate with: npx payload generate-secret
PAYLOAD_SECRET=payload-dev-secret-change-in-production

# Next.js configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development